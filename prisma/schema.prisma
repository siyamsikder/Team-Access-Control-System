generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String @id @default(cuid())
  email     String @unique
  password  String
  name      String
  role      Role   @default(USER)
  teamId    String?

  team      Team?  @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Team {
  id          String @id @default(cuid())
  name        String @unique
  description String?
  code        String? @unique

  members     User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("teams")
}

enum Role {
  ADMIN
  MANAGER
  USER
  GUEST
}